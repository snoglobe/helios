{
  "name": "@snoglobe/helios",
  "version": "0.4.7",
  "description": "Autonomous ML research agent TUI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "helios": "dist/bootstrap.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/skills/bundled dist/skills/",
    "dev": "tsx src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snoglobe/helios.git"
  },
  "keywords": [
    "ml",
    "research",
    "agent",
    "tui",
    "autonomous",
    "claude",
    "openai"
  ],
  "author": "snoglobe",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@hono/node-server": "^1.19.0",
    "@inkjs/ui": "^2.0.0",
    "@mozilla/readability": "^0.6.0",
    "@openai/codex-sdk": "^0.112.0",
    "@openauthjs/openauth": "^0.4.3",
    "asciichart": "^1.5.25",
    "better-sqlite3": "^11.8.1",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "fullscreen-ink": "^0.1.0",
    "hono": "^4.7.0",
    "ink": "^6.0.0",
    "ink-scroll-view": "^0.3.6",
    "ink-text-input": "^6.0.0",
    "linkedom": "^0.18.12",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "ssh2": "^1.16.0",
    "unpdf": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/asciichart": "^1.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
